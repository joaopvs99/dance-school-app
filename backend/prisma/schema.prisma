generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilizador {
  id        Int           @id @default(autoincrement())
  nome      String
  email     String        @unique
  password  String
  role      Role          @default(ENCARREGADO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  educandos Aluno[]
  artigos   ArtigoTroca[]
}

model Aluno {
  id             Int              @id @default(autoincrement())
  numAluno       String           @unique
  nome           String
  dataNascimento DateTime
  utilizadorId   Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  encarregado    Utilizador?      @relation(fields: [utilizadorId], references: [id])
  sessoes        SessaoCoaching[]
}

model SessaoCoaching {
  id        Int          @id @default(autoincrement())
  dataHora  DateTime
  estado    EstadoSessao @default(AGENDADA)
  alunoId   Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  aluno     Aluno        @relation(fields: [alunoId], references: [id])
}

model ArtigoTroca {
  id           Int          @id @default(autoincrement())
  titulo       String
  descricao    String?
  tamanho      String
  fotoUrl      String
  estado       EstadoArtigo @default(DISPONIVEL)
  utilizadorId Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  dono         Utilizador   @relation(fields: [utilizadorId], references: [id])
}

enum Role {
  DIRECAO
  PROFESSOR
  ENCARREGADO
}

enum EstadoSessao {
  AGENDADA
  CONCLUIDA
  CANCELADA
}

enum EstadoArtigo {
  DISPONIVEL
  TROCADO
  REMOVIDO
  MANUTENCAO
}
