# =========================================
# 1. DEPENDÊNCIAS (Obrigatoriamente ignorado)
# =========================================
# Ignora as pastas pesadas em todo o lado
node_modules/
/frontend/node_modules/
/backend/node_modules/

# =========================================
# 2. SEGREDOS E CHAVES (Segurança Máxima)
# =========================================
# Nunca enviar as passwords da base de dados (Neon) ou Cloudinary para o GitHub!
.env
.env.*
*.local
# (Opcional) Permite enviar um ficheiro de exemplo vazio se o criarem
!.env.example

# =========================================
# 3. PASTAS DE COMPILAÇÃO (Geradas pelo Vite/React)
# =========================================
# O código minificado que vai para produção não precisa de ir para o GitHub
/frontend/dist/
/frontend/build/
.vercel/

# =========================================
# 4. FICHEIROS TEMPORÁRIOS DO SERVIDOR
# =========================================
# Se testarem uploads de fotos no PC antes de enviarem para a cloud
/backend/uploads/
/backend/temp/

# =========================================
# 5. LOGS DE ERROS
# =========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================
# 6. SISTEMA OPERATIVO E EDITORES DE CÓDIGO
# =========================================
.DS_Store
Thumbs.db
.vscode/
.idea/